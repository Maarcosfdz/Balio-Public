# ── Database ──────────────────────────────────────────────────
DB_HOST=your-production-db-host.example.com
DB_PORT=5432
DB_NAME=balio
DB_USERNAME=balio_user
DB_PASSWORD=change_me_production_password
DB_EXTRA_PARAMS=?sslmode=require

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SIGN_KEY=change_me_to_a_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRATION=15
JWT_REFRESH_EXPIRATION_DAYS=7

# ── CORS / Frontend ───────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# ── Enable Banking / Open Banking ─────────────────────────────
ENABLE_BANKING_APP_ID=00000000-0000-0000-0000-000000000000
ENABLE_BANKING_PRIVATE_KEY_PATH=/app/secrets/enablebanking.pem
ENABLE_BANKING_REDIRECT_URI=https://your-api.example.com/bank/enablebanking/callback

# ── Logging ───────────────────────────────────────────────────
SHOW_SQL=false
LOG_FLYWAY=WARN
LOG_SPRING=WARN
