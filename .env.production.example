# ── Database (Neon) ───────────────────────────────────────────
DB_HOST=ep-xxxx.eu-west-2.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=your_neon_password
DB_EXTRA_PARAMS=?sslmode=require&channel_binding=require

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SIGN_KEY=change_me_to_a_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRATION=15
JWT_REFRESH_EXPIRATION_DAYS=7

# ── CORS / Frontend ───────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# ── Logging ───────────────────────────────────────────────────
SHOW_SQL=false
LOG_FLYWAY=WARN
LOG_SPRING=WARN
