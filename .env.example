# ============================================================
# Balio — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it's in .gitignore.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=balio
DB_USERNAME=balio
DB_PASSWORD=baliopass

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong key (min 256 bits / 32 chars):
#   openssl rand -base64 48
JWT_SIGN_KEY=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_ACCESS_EXPIRATION=15
JWT_REFRESH_EXPIRATION_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Logging ──────────────────────────────────────────────────
SHOW_SQL=false
LOG_FLYWAY=INFO
LOG_SPRING=INFO
